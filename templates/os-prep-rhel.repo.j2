# Managed by playbooks/os-setup.yaml — do not edit by hand.
[baseos]
name=BaseOS
baseurl={{ os_prep_rhel_release_root }}/compose/BaseOS/{{ os_prep_rhel_arch }}/os/
enabled=1
gpgcheck=0

[appstream]
name=AppStream
baseurl={{ os_prep_rhel_release_root }}/compose/AppStream/{{ os_prep_rhel_arch }}/os/
enabled=1
gpgcheck=0

{% if os_prep_include_crb | default(false) | bool %}
[crb]
name=CRB
baseurl={{ os_prep_rhel_release_root }}/compose/CRB/{{ os_prep_rhel_arch }}/os/
enabled=1
gpgcheck=0
{% endif %}
