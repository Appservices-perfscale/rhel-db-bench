# Generated by playbooks/auto-schedule.yaml — do not edit hostnames manually after schedule.
# First scheduled host → bench-vm; second → client-vm.
# This file is gitignored — safe for credentials.

[bench]
bench-vm ansible_host={{ bench_hostname }} ansible_ssh_pass={{ scalelab_ssh_pass }} os_prep_badfish_host=mgmt-{{ bench_hostname }}

[client]
client-vm ansible_host={{ client_hostname }} ansible_ssh_pass={{ scalelab_ssh_pass }} os_prep_badfish_host=mgmt-{{ client_hostname }}

[remote:vars]
# Foreman + Badfish credentials for major version rebuilds (e.g. 9→10).
# Derived from the QUADS assignment: cloud name + ticket number.
os_prep_foreman_url={{ foreman_url | default('https://foreman.rdu2.scalelab.redhat.com/api/v2') }}
os_prep_foreman_username={{ _foreman_username }}
os_prep_foreman_password={{ _foreman_password }}
os_prep_badfish_username=quads
os_prep_badfish_password={{ _foreman_password }}
