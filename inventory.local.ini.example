# Usually auto-generated by: ansible-playbook playbooks/auto-schedule.yaml
# Requires scalelab_ssh_pass in quads_cfg.yaml (or existing inventory.local.ini password).
# Ansible merges this with inventory.ini (bench-vm, client-vm).
# This file is gitignored — safe for credentials.

[bench]
bench-vm ansible_host=bench.example.com ansible_ssh_pass=CHANGEME os_prep_badfish_host=mgmt-bench.example.com

[client]
client-vm ansible_host=client.example.com ansible_ssh_pass=CHANGEME os_prep_badfish_host=mgmt-client.example.com

[remote:vars]
# Foreman + Badfish credentials for major version rebuilds (e.g. 9→10).
# Auto-derived from the QUADS assignment: cloud name + rdu2@<ticket_number>.
os_prep_foreman_url=http://foreman.rdu2.scalelab.redhat.com/api/v2
os_prep_foreman_username=cloud42
os_prep_foreman_password=rdu2@12345
os_prep_badfish_username=quads
os_prep_badfish_password=rdu2@12345
