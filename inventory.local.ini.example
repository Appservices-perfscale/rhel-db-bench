# Usually auto-generated by: ansible-playbook playbooks/auto-schedule.yaml
# Requires scalelab_ssh_pass in quads_cfg.yaml (or existing inventory.local.ini password).
# Ansible merges this with inventory.ini (bench-vm, client-vm).

[bench]
bench-vm ansible_host=bench.example.com ansible_ssh_pass=CHANGEME

[client]
client-vm ansible_host=client.example.com ansible_ssh_pass=CHANGEME
